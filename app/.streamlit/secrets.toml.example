# Streamlit Community Cloud → App → Settings → Secrets.
# Paste ONE of the two config styles below (DATABASE_URL is simplest for Neon).

# --- Option A: single connection URL (recommended, e.g. Neon/Supabase) ---
DATABASE_URL = "postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Option B: discrete fields (instead of DATABASE_URL) ---
# DB_HOST = "your-host"
# DB_PORT = "5432"
# DB_NAME = "parking_db"
# DB_USER = "your-user"
# DB_PASSWORD = "your-password"

# Admin login for the app's sign-in screen. CHANGE THIS.
APP_ADMIN_PASSWORD = "pick-a-password"
