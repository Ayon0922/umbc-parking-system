# Copy this file to .env and adjust. .env is git-ignored.
# ---- Database ----
DB_NAME=parking_db
DB_USER=umbc_admin
DB_PASSWORD=umbc_password
DB_PORT=5432

# ---- Streamlit app ----
APP_PORT=8501
# Password for the admin login screen. CHANGE THIS for any real deployment.
APP_ADMIN_PASSWORD=admin
# Set to false to open the app without a login gate (handy for public demos/dev).
APP_REQUIRE_AUTH=true

# ---- pgAdmin (optional web DB client) ----
PGADMIN_EMAIL=admin@umbc.edu
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
